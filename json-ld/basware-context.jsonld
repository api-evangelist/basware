      "@type": "rdf:Property",
      "rdfs:comment": "ExternalCode of Permission that is granted. Needs to be a Permission that is available in the application selected in 'applicationExternalCode'."
    },
    "consumers": {
      "@id": "basware:consumers",
      "@type": "rdf:Property",
      "rdfs:comment": "List of consumer identifiers for whom default user groups should be created.\r Permissible values: P2P, BwAdmin, SmartPdf."
    },
    "permissions": {
      "@id": "basware:permissions",
      "@type": "rdf:Property",
      "rdfs:comment": "Gets or sets the list of permission ID's associated with the user group."
    },
    "userGroupExternalCode": {
      "@id": "basware:userGroupExternalCode",
      "@type": "rdf:Property"
    },
    "cdmErrorMappingOrganizationCode": {
      "@id": "basware:cdmErrorMappingOrganizationCode",
      "@type": "rdf:Property"
    },
    "userGroupAssociatedUsers": {
      "@id": "basware:userGroupAssociatedUsers",
      "@type": "rdf:Property",
      "rdfs:comment": "Collection of user-group associations to be created or updated."
    },
    "userGroupPermissions": {
      "@id": "basware:userGroupPermissions",
      "@type": "rdf:Property",
      "rdfs:comment": "Collection of user group permissions to be created or updated."
    },
    "userGroups": {
      "@id": "basware:userGroups",
      "@type": "rdf:Property",
      "rdfs:comment": "Collection of user groups to be created or updated."
    },
    "organizationExternalCodes": {
      "@id": "basware:organizationExternalCodes",
      "@type": "rdf:Property"
    },
    "autoResponseMode": {
      "@id": "basware:autoResponseMode",
      "@type": "rdf:Property",
      "rdfs:comment": "Determines whether task autoresponder is enabled and whether it returns task responses with status 'Success' or 'Failed'. The entire autoresponder functionality is reserved for later use."
    },
    "autoResponseMessage": {
      "@id": "basware:autoResponseMessage",
      "@type": "rdf:Property",
      "rdfs:comment": "Determines message returned by task autoresponser to P2P."
    },
    "fieldUpdateArray": {
      "@id": "basware:fieldUpdateArray",
      "@type": "rdf:Property",
      "rdfs:comment": "Reserved for later use. Array of field values to automatically update when autoresponder is enabled."
    },
    "numberOfRecordsDeleted": {
      "@id": "basware:numberOfRecordsDeleted",
      "@type": "rdf:Property",
      "rdfs:comment": "Number of records deleted"
    },
    "fieldId": {
      "@id": "basware:fieldId",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies the field to update. Use JSONpath to identify the value on response schema to update."
    },
    "updateToValue": {
      "@id": "basware:updateToValue",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies value to which field contents are set by the autoresponder."
    },
    "taskId": {
      "@id": "basware:taskId",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines id of task"
    },
    "taskType": {
      "@id": "basware:taskType",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines task type"
    },
    "taskSubType": {
      "@id": "basware:taskSubType",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines sub task type"
    },
    "documentId": {
      "@id": "basware:documentId",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines document id"
    },
    "expirationTime": {
      "@id": "basware:expirationTime",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines notification's expiration time"
    },
    "detail": {
      "@id": "basware:detail",
      "@type": "rdf:Property",
      "rdfs:comment": "Detail of error"
    },
    "subscriptionType": {
      "@id": "basware:subscriptionType",
      "@type": "rdf:Property",
      "rdfs:comment": "Subscription type. Supported values: 'Webhook'. 'Polling' subscription type is reserved for later use."
    },
    "notificationWebhookURL": {
      "@id": "basware:notificationWebhookURL",
      "@type": "rdf:Property",
      "rdfs:comment": "URL where API posts push notifications when subscriptionType = 'Webhook' (then field is mandatory). This URL needs to implement the Basware's notification receival API specification."
    },
    "webhookAuthenticationToken": {
      "@id": "basware:webhookAuthenticationToken",
      "@type": "rdf:Property",
      "rdfs:comment": "Secret key used by API to sign sent push notifications so authenticity can be verified by customer. Mandatory when subscription type is 'Webhook'."
    },
    "autoResponder": {
      "@id": "basware:autoResponder",
      "@type": "rdf:Property",
      "rdfs:comment": "Reserved for later use."
    },
    "subscriptions": {
      "@id": "basware:subscriptions",
      "@type": "rdf:Property"
    },
    "externalProcessingTime": {
      "@id": "basware:externalProcessingTime",
      "@type": "rdf:Property",
      "rdfs:comment": "Reserved for future use."
    },
    "isSimulatedTask": {
      "@id": "basware:isSimulatedTask",
      "@type": "rdf:Property",
      "rdfs:comment": "Reserved for future use. Indicates if task is a simulated task (created using 'simulate' API)."
    },
    "taskHistory": {
      "@id": "basware:taskHistory",
      "@type": "rdf:Property",
      "rdfs:comment": "Shows information aboout task status changes."
    },

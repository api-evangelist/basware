    },
    "lastUpdatedEndDate": {
      "@id": "basware:lastUpdatedEndDate",
      "@type": "rdf:Property"
    },
    "quantityUnitCode": {
      "@id": "basware:quantityUnitCode",
      "@type": "rdf:Property",
      "rdfs:comment": "Quantity unit code."
    },
    "deliveryTermCode": {
      "@id": "basware:deliveryTermCode",
      "@type": "rdf:Property",
      "rdfs:comment": "Identifier for the agreed delivery term for the item. If empty, supplier's delivery term is used."
    },
    "attachOrderPdfToXml": {
      "@id": "basware:attachOrderPdfToXml",
      "@type": "rdf:Property",
      "rdfs:comment": "Indicates whether the order PDF will be attached to the XML order sent to the supplier."
    },
    "orderOwnerEmailAddress": {
      "@id": "basware:orderOwnerEmailAddress",
      "@type": "rdf:Property",
      "rdfs:comment": "Recipient email address where order is sent when orderRecipientType is set as Owner or SupplierAndOwner."
    },
    "supplierEmailAddress": {
      "@id": "basware:supplierEmailAddress",
      "@type": "rdf:Property",
      "rdfs:comment": "Email address used to override the default supplier email address, when orderRecipientType is Supplier or SupplierAndOwner."
    },
    "hasErrors": {
      "@id": "basware:hasErrors",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies whether the request has errors."
    },
    "tenants": {
      "@id": "basware:tenants",
      "@type": "rdf:Property",
      "rdfs:comment": "Optional tenant list for filtering access by tenant. If left empty user is granted access to all tenants he has the system level access."
    },
    "applicationCode": {
      "@id": "basware:applicationCode",
      "@type": "rdf:Property"
    },
    "applicationPermissions": {
      "@id": "basware:applicationPermissions",
      "@type": "rdf:Property"
    },
    "organisations": {
      "@id": "basware:organisations",
      "@type": "rdf:Property"
    },
    "isNewOrganization": {

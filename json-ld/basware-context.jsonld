    },
    "subscribedService": {
      "@id": "basware:subscribedService",
      "@type": "rdf:Property",
      "rdfs:comment": "Currently the \u2018subscribedService\u2019 -parameter value is ignored and data is distributed to all target systems. This is likely to be enhanced in a further release to allow specifying the target system."
    },
    "version": {
      "@id": "basware:version",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies the API version, as in /v1/projects or /v2/projects. Default value: V1."
    },
    "ignoreSuccessfullItems": {
      "@id": "basware:ignoreSuccessfullItems",

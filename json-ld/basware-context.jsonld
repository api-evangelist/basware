      "@id": "basware:timeStamp",
      "@type": "rdf:Property",
      "rdfs:comment": "Timestamp when action occurred."
    },
    "messages": {
      "@id": "basware:messages",
      "@type": "rdf:Property",
      "rdfs:comment": "Additional information regarding task status change, such as error messages."
    },
    "hasError": {
      "@id": "basware:hasError",
      "@type": "rdf:Property",
      "rdfs:comment": "Tells that request has error"
    },
    "errorMessages": {
      "@id": "basware:errorMessages",
      "@type": "rdf:Property"
    },
    "access_token": {
      "@id": "basware:access_token",
      "@type": "rdf:Property",
      "rdfs:comment": "oauth token"
    },
    "scope": {
      "@id": "basware:scope",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines scope of token"
    },
    "expires_in": {
      "@id": "basware:expires_in",
      "@type": "rdf:Property",
      "rdfs:comment": "tells tokens expiration in minutes"
    },
    "token_type": {
      "@id": "basware:token_type",
      "@type": "rdf:Property",
      "rdfs:comment": "tells type of token"
    },
    "grant_type": {
      "@id": "basware:grant_type",
      "@type": "rdf:Property",
      "rdfs:comment": "Oauth2 grant type. Supported value(s): 'client_credentials' = Client credential authentication flow."
    },
    "issuer": {
      "@id": "basware:issuer",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines token issuer"
    },

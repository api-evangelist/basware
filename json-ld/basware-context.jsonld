    "organizations": {
      "@id": "basware:organizations",
      "@type": "rdf:Property"
    },
    "goodsReceiptLineNumber": {
      "@id": "basware:goodsReceiptLineNumber",
      "@type": "rdf:Property",
      "rdfs:comment": "Goods receipt line number."
    },
    "bestFitGrouping": {
      "@id": "basware:bestFitGrouping",
      "@type": "rdf:Property",
      "rdfs:comment": "Grouping factor for received items that are invoiced together without any delivery indicator. The value can be for example a delivery note number or a delivery date. Used in best-fit matching."
    },
    "isDeleted": {
      "@id": "basware:isDeleted",
      "@type": "rdf:Property",
      "rdfs:comment": "Indicates whether the received item is deleted. If TRUE, the received item has been marked as deleted. Default value: FALSE."
    },
    "invoicedQuantity": {
      "@id": "basware:invoicedQuantity",
      "@type": "rdf:Property",
      "rdfs:comment": "Quantity that already has been matched from the line item"
    },
    "invoicedNetSum": {
      "@id": "basware:invoicedNetSum",
      "@type": "rdf:Property",
      "rdfs:comment": "Sum that already has been matched excluding tax"
    },
    "invoicedGrossSum": {
      "@id": "basware:invoicedGrossSum",
      "@type": "rdf:Property",
      "rdfs:comment": "Sum that already has been matched including tax"
    },
    "subUnitOfMeasure": {
      "@id": "basware:subUnitOfMeasure",
      "@type": "rdf:Property",
      "rdfs:comment": "Alternative unit of measurement of the line item. Valid value is UN/ECE CEFACT Trade Facilitation Recommendation No. 20 common code value represented as string."
    },
    "goodsReceiptType": {
      "@id": "basware:goodsReceiptType",
      "@type": "rdf:Property",
      "rdfs:comment": "Goods receipt type, specified by Customer."
    },
    "receiveMethod": {
      "@id": "basware:receiveMethod",
      "@type": "rdf:Property",
      "rdfs:comment": "Receive method, specified by customer."
    },
    "voucherNumber": {
      "@id": "basware:voucherNumber",
      "@type": "rdf:Property",
      "rdfs:comment": "A reference to a buyer-generated document that authorizes a purchase transaction"
    },
    "goodsReceiptNote": {
      "@id": "basware:goodsReceiptNote",
      "@type": "rdf:Property",
      "rdfs:comment": "Free-form text applying to the goods receipt. This field may contain notes or any other similar information that is not contained explicitly in another structure."
    },
    "fiscalYear": {
      "@id": "basware:fiscalYear",
      "@type": "rdf:Property",
      "rdfs:comment": "Used when goods or services are received this fiscal year and will be paid for next fiscal year"
    },
    "deliveryDate": {
      "@id": "basware:deliveryDate",
      "@type": "rdf:Property",
      "rdfs:comment": "Date when the goods/services are delivered. Valid values are in format: CCYY-MM-DD. If the time zone is known, it must be represented with +hh:mm or -hh:mm or Z (which means UTC). If the time zone is "
    },
    "comment": {
      "@id": "basware:comment",
      "@type": "rdf:Property",
      "rdfs:comment": "Available for additional information regarding the goods receipt, such as description of damaged goods."
    },
    "serviceEntrySheetDocId": {
      "@id": "basware:serviceEntrySheetDocId",
      "@type": "rdf:Property",
      "rdfs:comment": "Custom field in the business document"
    },
    "receiptCoding": {
      "@id": "basware:receiptCoding",
      "@type": "rdf:Property",
      "rdfs:comment": "ReceiptCoding (for Service POs only) defines default coding dimension values for matched invoice lines. For Service POs, only one codingRow is allowed."
    },
    "orderLineExternalCode": {
      "@id": "basware:orderLineExternalCode",
      "@type": "rdf:Property",
      "rdfs:comment": "External code of the order line for which goods/services are being received."
    },
    "referenceGRLineExternalCode": {
      "@id": "basware:referenceGRLineExternalCode",
      "@type": "rdf:Property",
      "rdfs:comment": "Used when this receipt item is a negative return/cancellation item for an earlier receipt. Needs to match with externalCode of the original goods receipt line."
    },
    "inherited": {
      "@id": "basware:inherited",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies whether the identifier has been inherited from a parent company. Legal identifiers for Units are automatically inherited from parent Company."
    },

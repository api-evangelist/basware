      "@id": "basware:clientUUID",
      "@type": "rdf:Property",
      "rdfs:comment": "Document identifier created by client. Unique ID in client's namespace. It is returned in the response as a correlation ID. Not to be confused with the documentId (eg invoice number)."
    },
    "senderName": {
      "@id": "basware:senderName",
      "@type": "rdf:Property",
      "rdfs:comment": "Name of the document sender. For invoice, supplier name."
    },
    "senderIds": {
      "@id": "basware:senderIds",
      "@type": "rdf:Property",
      "rdfs:comment": "Array of IDs identifying the sender. Total size of the array should not exceed: 300 chars"
    },
    "recipientName": {
      "@id": "basware:recipientName",
      "@type": "rdf:Property",
      "rdfs:comment": "Name of the document recipient. For invoice, receiving company's name."
    },
    "recipientIds": {
      "@id": "basware:recipientIds",
      "@type": "rdf:Property",
      "rdfs:comment": "Array of IDs identifying the recipient. Total size of the array should not exceed: 300 chars"
    },
    "tradingPartner": {
      "@id": "basware:tradingPartner",
      "@type": "rdf:Property",
      "rdfs:comment": "Name of the document recipient or sender. For invoice, receiving company's name or supplier name."
    },
    "documentDate": {
      "@id": "basware:documentDate",
      "@type": "rdf:Property",
      "rdfs:comment": "Date of the document. For invoice, normally invoice date. ISO 8601"
    },
    "buyerReferenceId": {
      "@id": "basware:buyerReferenceId",
      "@type": "rdf:Property",
      "rdfs:comment": "An identifier assigned by the Buyer used for internal routing purposes."
    },
    "buyerReferenceType": {
      "@id": "basware:buyerReferenceType",
      "@type": "rdf:Property",
      "rdfs:comment": "Type of buyerReferenceId. Freetext field. eg. email, name, VAT"
    },
    "amount": {
      "@id": "basware:amount",
      "@type": "rdf:Property",
      "rdfs:comment": "Amount of document. For invoice, use net sum."
    },
    "flowDirection": {
      "@id": "basware:flowDirection",
      "@type": "rdf:Property",
      "rdfs:comment": "Document flow direction. Either sending or receiving."
    },

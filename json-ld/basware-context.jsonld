    },
    "publishDraftChildrenOnly": {
      "@id": "basware:publishDraftChildrenOnly",
      "@type": "rdf:Property"
    },
    "externalGRNumber": {
      "@id": "basware:externalGRNumber",
      "@type": "rdf:Property",
      "rdfs:comment": "Goods receipt document number in the system from which it is being imported."
    },
    "receiveDate": {
      "@id": "basware:receiveDate",
      "@type": "rdf:Property",
      "rdfs:comment": "Date on which goods have been received."
    },
    "referenceGRDocumentExternalCode": {
      "@id": "basware:referenceGRDocumentExternalCode",
      "@type": "rdf:Property",
      "rdfs:comment": "Indicates a return/cancellation for an earlier receipt. In such case, 1) this field needs to contain value of 'externalCode' field of the original goods receipt document and 2) lineReceivings need to "
    },
    "lineReceivings": {
      "@id": "basware:lineReceivings",
      "@type": "rdf:Property",
      "rdfs:comment": "List of individual goods receipt lines."
    },
    "purchasing": {
      "@id": "basware:purchasing",
      "@type": "rdf:Property",
      "rdfs:comment": "Whether user has access to Purchase Manager module or not."
    },
    "travel": {
      "@id": "basware:travel",
      "@type": "rdf:Property",
      "rdfs:comment": "Whether user has access to Travel & Expense module or not."
    },
    "spendManager": {
      "@id": "basware:spendManager",
      "@type": "rdf:Property",
      "rdfs:comment": "Whether user has access to Spend Manager module or not."
    },
    "assets": {
      "@id": "basware:assets",
      "@type": "rdf:Property",
      "rdfs:comment": "Whether user has access to Asset Manager module or not."
    },
    "budgets": {
      "@id": "basware:budgets",
      "@type": "rdf:Property",
      "rdfs:comment": "Whether user has access to Budget Manager module or not."
    },
    "shipToCode": {
      "@id": "basware:shipToCode",
      "@type": "rdf:Property"
    },
    "shipToName": {
      "@id": "basware:shipToName",
      "@type": "rdf:Property"
    },
    "billToCode": {
      "@id": "basware:billToCode",
      "@type": "rdf:Property"
    },
    "billToName": {
      "@id": "basware:billToName",
      "@type": "rdf:Property"
    },
    "chargeToCode": {

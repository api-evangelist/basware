      "@type": "rdf:Property",
      "rdfs:comment": "Defines the exponent"
    },
    "kid": {
      "@id": "basware:kid",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines the unique identifier for the key"
    },
    "kty": {
      "@id": "basware:kty",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines the key type"
    },
    "n": {
      "@id": "basware:n",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines the modulus"
    },
    "use": {
      "@id": "basware:use",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines how the key was meant to be used"
    },
    "alg": {
      "@id": "basware:alg",

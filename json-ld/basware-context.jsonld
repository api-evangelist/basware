      "@id": "basware:companies",
      "@type": "rdf:Property",
      "rdfs:comment": "List of company units to associate account to P2P organization hierarchy"
    },
    "externalCode": {
      "@id": "basware:externalCode",
      "@type": "rdf:Property",
      "rdfs:comment": "External identifier that is used as a key in API."
    },
    "lastUpdated": {
      "@id": "basware:lastUpdated",
      "@type": "rdf:Property",
      "rdfs:comment": "Timestamp when the record was last sent to API. Set automatically."
    },
    "accounts": {
      "@id": "basware:accounts",
      "@type": "rdf:Property"
    },
    "invoiceId": {
      "@id": "basware:invoiceId",
      "@type": "rdf:Property",
      "rdfs:comment": "Unique identifier for an invoice generated by Basware P2P. Must be returned in when sending acknowledgement, transferResponse or paymentResponse to the invoice."
    },
    "bumid": {
      "@id": "basware:bumid",
      "@type": "rdf:Property",
      "rdfs:comment": "Unique identifier for a business document generated by BT, used between Basware P2P and other Basware systems."
    },
    "p2pProcessingMode": {
      "@id": "basware:p2pProcessingMode",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies the P2P processing mode for the invoice. Standard = Ivoice has been processed in Basware P2P and is approved for payment. InvoiceEnrichment = Invoice data contents have been enriched for pro"
    },
    "invoiceNumber": {
      "@id": "basware:invoiceNumber",
      "@type": "rdf:Property",
      "rdfs:comment": "Invoice number (from supplier)."
    },
    "voucherNumber1": {
      "@id": "basware:voucherNumber1",
      "@type": "rdf:Property",
      "rdfs:comment": "Voucher Number 1 (for accounting). Voucher numbers can be generated by Basware or returned from customer ERP."
    },
    "voucherNumber2": {
      "@id": "basware:voucherNumber2",
      "@type": "rdf:Property",
      "rdfs:comment": "Voucher Number 2 (for accounting). Voucher numbers can be generated by Basware or returned from customer ERP."
    },
    "voucherDate": {
      "@id": "basware:voucherDate",
      "@type": "rdf:Property",
      "rdfs:comment": "Voucher date can be used to determine the target accounting period for invoice in receiving (ERP) system."
    },
    "processingStatus": {
      "@id": "basware:processingStatus",
      "@type": "rdf:Property",
      "rdfs:comment": "Processing status of the invoice in Basware API."
    },
    "originService": {
      "@id": "basware:originService",
      "@type": "rdf:Property",
      "rdfs:comment": "Describes how the invoice got created (as e-invoice, scanned from paper, extracted from pdf, etc)"
    },
    "companyName": {
      "@id": "basware:companyName",
      "@type": "rdf:Property",
      "rdfs:comment": "Company name."
    },
    "organizationCode": {
      "@id": "basware:organizationCode",
      "@type": "rdf:Property",
      "rdfs:comment": "Organization element in the higher level of the organization than companyCode. This organization element collects the spend from the lower organization units."
    },
    "organizationName": {
      "@id": "basware:organizationName",
      "@type": "rdf:Property",
      "rdfs:comment": "Organization element name."
    },
    "supplierCode": {
      "@id": "basware:supplierCode",
      "@type": "rdf:Property",
      "rdfs:comment": "A party that supplied goods or services referred in the invoice."
    },
    "supplierName": {
      "@id": "basware:supplierName",
      "@type": "rdf:Property",
      "rdfs:comment": "Supplier name."
    },
    "currencyCode": {
      "@id": "basware:currencyCode",
      "@type": "rdf:Property",
      "rdfs:comment": "Invoice currency."
    },
    "netSum": {
      "@id": "basware:netSum",
      "@type": "rdf:Property",
      "rdfs:comment": "Invoice net sum (invoice total without tax), in invoice currecy."
    },
    "grossSum": {
      "@id": "basware:grossSum",
      "@type": "rdf:Property",
      "rdfs:comment": "Invoice gross sum (invoice total with tax), in invoice currecy."
    },
    "taxPercent1": {
      "@id": "basware:taxPercent1",
      "@type": "rdf:Property",
      "rdfs:comment": "Tax percentage."
    },
    "taxPercent2": {
      "@id": "basware:taxPercent2",
      "@type": "rdf:Property",
      "rdfs:comment": "Second tax percentage (for example for partially deductible VAT)."
    },
    "taxSum1": {
      "@id": "basware:taxSum1",
      "@type": "rdf:Property",
      "rdfs:comment": "Invoice tax sum to be paid, in invoice currency."
    },
    "taxSum2": {
      "@id": "basware:taxSum2",
      "@type": "rdf:Property",
      "rdfs:comment": "Invoice tax sum that is excluded from the tax sum to be paid, in invoice currency."
    },
    "invoiceDate": {
      "@id": "basware:invoiceDate",
      "@type": "rdf:Property",
      "rdfs:comment": "Invoice date (from supplier)."
    },
    "baseLineDate": {
      "@id": "basware:baseLineDate",
      "@type": "rdf:Property"
    },
    "dueDate": {
      "@id": "basware:dueDate",

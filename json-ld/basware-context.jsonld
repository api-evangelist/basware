    },
    "invoicingSupplierName": {
      "@id": "basware:invoicingSupplierName",
      "@type": "rdf:Property",
      "rdfs:comment": "Name of supplier sending the invoice."
    },
    "requestedDeliveryDate": {
      "@id": "basware:requestedDeliveryDate",
      "@type": "rdf:Property",
      "rdfs:comment": "Date when goods/services are expected to be delivered. Valid values are in format: CCYY-MM-DD. If the time zone is known, it must be represented with +hh:mm or -hh:mm or Z (which means UTC). If the ti"
    },
    "actualDeliveryDate": {
      "@id": "basware:actualDeliveryDate",
      "@type": "rdf:Property",
      "rdfs:comment": "Date when goods/services were delivered. Valid values are in format: CCYY-MM-DD. If the time zone is known, it must be represented with +hh:mm or -hh:mm or Z (which means UTC). If the time zone is not"
    },
    "isInvoiced": {
      "@id": "basware:isInvoiced",
      "@type": "rdf:Property",
      "rdfs:comment": "Indicates whether the purchase order is invoiced. By default, the field does not impact the matching logic in P2P."
    },
    "isDelivered": {
      "@id": "basware:isDelivered",
      "@type": "rdf:Property",
      "rdfs:comment": "Indicates whether the purchase order is delivered. By default, the field does not impact the matching logic in P2P."
    },
    "orderReference": {
      "@id": "basware:orderReference",
      "@type": "rdf:Property",
      "rdfs:comment": "Reference to parent order. Allows an invoice to be matched to child order(s) under the parent order. Intended for scenarios where one order number is given to supplier while customer keeps generating "
    },
    "requisitionLines": {
      "@id": "basware:requisitionLines",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies the requisition lines which are on-course for being grouped to this order."
    },
    "netTotal": {
      "@id": "basware:netTotal",
      "@type": "rdf:Property",
      "rdfs:comment": "Represents total excluding tax that is allocated for the accounting dimensions set in the coding row item. Note: Either net or gross currency amounts are required on the entire purchase order (both ca"
    },
    "grossTotal": {
      "@id": "basware:grossTotal",
      "@type": "rdf:Property",
      "rdfs:comment": "Represents total including tax that is allocated for the accounting dimensions set in the coding row item. Note: Either net or gross currency amounts are required on the entire purchase order (both ca"
    },
    "conversionDeNumerator": {
      "@id": "basware:conversionDeNumerator",
      "@type": "rdf:Property",
      "rdfs:comment": "Deprecated - field not in use."
    },
    "partnerProfitCenter": {
      "@id": "basware:partnerProfitCenter",
      "@type": "rdf:Property",
      "rdfs:comment": "Identifies transfers of goods and services between profit centers"
    },
    "commitmentItem": {
      "@id": "basware:commitmentItem",
      "@type": "rdf:Property",
      "rdfs:comment": "A code to identify an element that represents the functional grouping of expenditures and revenues within a financial management area"
    },
    "controllingArea": {
      "@id": "basware:controllingArea",
      "@type": "rdf:Property",
      "rdfs:comment": "A code to identify an organizational unit in an organization that represents a closed system used for cost accounting purposes"
    },
    "functionalArea": {
      "@id": "basware:functionalArea",
      "@type": "rdf:Property",
      "rdfs:comment": "A code to identify a functional area, like teams of employees, who have similar skills and expertise"
    },
    "allocatedQuantity": {
      "@id": "basware:allocatedQuantity",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies quantity per coding-line. Needed especially when creating multiple coding lines for a single order row."
    },
    "network": {
      "@id": "basware:network",
      "@type": "rdf:Property"
    },
    "networkActivity": {
      "@id": "basware:networkActivity",
      "@type": "rdf:Property"
    },
    "orderExternalCode": {
      "@id": "basware:orderExternalCode",
      "@type": "rdf:Property",
      "rdfs:comment": "Links the order line to the corresponding order header. The header needs to have been posted to API before order line(s)."
    },
    "lineNumber": {
      "@id": "basware:lineNumber",
      "@type": "rdf:Property",
      "rdfs:comment": "Purchase order row number."
    },
    "sortNumber": {
      "@id": "basware:sortNumber",
      "@type": "rdf:Property",
      "rdfs:comment": "Technical row number, used also for sorting. Typically the same as purchase order row number."
    },
    "matchingMode": {
      "@id": "basware:matchingMode",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies how the order row is handled when matching invoice lines to order lines.\r 'Standard' - Standard matching, based on quantities and sums.\r 'Blanket' - Matching is based on sum. Quantity is fix"
    },
    "isReceiptRequired": {
      "@id": "basware:isReceiptRequired",
      "@type": "rdf:Property",
      "rdfs:comment": "Indicates whether the line item requires receipts. When FALSE, the line item does not require receipts. When TRUE, the system evaluates the received quantity and sum at the time of matching. When fiel"
    },
    "isReceiptBasedMatching": {
      "@id": "basware:isReceiptBasedMatching",
      "@type": "rdf:Property",
      "rdfs:comment": "Indicates whether the matching takes place with line item or a goods receipt. When FALSE, a matched invoice is associated with the purchase order line and one coding line is generated per matched orde"
    },
    "isOverreceivalAllowed": {
      "@id": "basware:isOverreceivalAllowed",
      "@type": "rdf:Property",
      "rdfs:comment": "Indicates whether over-delivery is allowed for the line item. When FALSE, the system evaluates the matching using the ordered quantity instead of possible higher quantity from receipts."
    },
    "isSelfApproved": {
      "@id": "basware:isSelfApproved",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies has the PO line bypassed standard requisition approval flow in PO source system before order line has been sent to P2P. If true, approval has been bypassed in PO seource system. Invoices mat"
    },
    "uom": {
      "@id": "basware:uom",
      "@type": "rdf:Property",
      "rdfs:comment": "Unit of measure of the line item. Valid value is UN/ECE CEFACT Trade Facilitation Recommendation No. 20 common code value represented as string."
    },
    "priceUnit": {
      "@id": "basware:priceUnit",
      "@type": "rdf:Property",
      "rdfs:comment": "The unit by which the line item is sold (boxes, litres, tons, pcs, kg, etc). Reguired when using line-level invoice matching with unit validation."
    },
    "priceUnitDescription": {
      "@id": "basware:priceUnitDescription",
      "@type": "rdf:Property",
      "rdfs:comment": "Name of the price unit."
    },
    "globalTradeItemNumber": {
      "@id": "basware:globalTradeItemNumber",
      "@type": "rdf:Property",
      "rdfs:comment": "The GTIN is a globally unique 14-digit number used to identify trade items, products, or services. Can also be used to match order rows to invoice lines."
    },
    "orderLineCoding": {
      "@id": "basware:orderLineCoding",
      "@type": "rdf:Property",
      "rdfs:comment": "Order line coding is used for adding values to coding dimensions. These values will be used by default when producing coding rows on the invoice line(s) matched to this order line. It is applicable fo"
    },
    "referenceUsers": {
      "@id": "basware:referenceUsers",
      "@type": "rdf:Property",
      "rdfs:comment": "Users related to order (buyer, owner, reference person, etc). Note: Not shown in old silverlight based P2P user interface. If this block is sent, userEmail or userExternalCode is required to identify "
    },
    "matchingOrderLines": {
      "@id": "basware:matchingOrderLines",
      "@type": "rdf:Property"
    },
    "userExternalCode": {
      "@id": "basware:userExternalCode",
      "@type": "rdf:Property",
      "rdfs:comment": "External code. Either userExternalCode or userEmail is required."
    },
    "userEmail": {
      "@id": "basware:userEmail",
      "@type": "rdf:Property",
      "rdfs:comment": "Email address. Either userExternalCode or userEmail is required."
    },
    "userRole": {
      "@id": "basware:userRole",
      "@type": "rdf:Property",
      "rdfs:comment": "User role."
    },
    "matchingOrders": {
      "@id": "basware:matchingOrders",
      "@type": "rdf:Property"
    },
    "country": {
      "@id": "basware:country",
      "@type": "rdf:Property"
    },
    "uiLabel": {
      "@id": "basware:uiLabel",
      "@type": "rdf:Property"
    },
    "isLegalIdentifier": {
      "@id": "basware:isLegalIdentifier",
      "@type": "rdf:Property"
    },
    "isRequiredforCountry": {
      "@id": "basware:isRequiredforCountry",
      "@type": "rdf:Property"
    },
    "activeFrom": {
      "@id": "basware:activeFrom",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies validity start date for the organization element."
    },
    "activeTo": {
      "@id": "basware:activeTo",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies validity end date for the organization element."
    },
    "businessIdentifiers": {
      "@id": "basware:businessIdentifiers",
      "@type": "rdf:Property",
      "rdfs:comment": "Company business identifiers. See \"Usage scenario 6: Import companies on Basware API developer site for explanation of available identifier type values. Note: Identifiers are not allowed on 'group' ty"
    },
    "pathToRoot": {
      "@id": "basware:pathToRoot",
      "@type": "rdf:Property",
      "rdfs:comment": "Lists all parent externalCodes on the way to root organization element (set automatically by API)."
    },
    "parentExternalCode": {
      "@id": "basware:parentExternalCode",
      "@type": "rdf:Property",
      "rdfs:comment": "External code of the parent company. Note: Parent company cannot be changed after the company is published (published = true)."
    },
    "parentCompanyCode": {
      "@id": "basware:parentCompanyCode",
      "@type": "rdf:Property",
      "rdfs:comment": "Company code of the parent company. This value is set automatically by API."
    },
    "level": {
      "@id": "basware:level",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies how many levels from root node the organization element resides from. This value is set automatically by API based on number of parents on the way to the root node."
    },
    "childCount": {
      "@id": "basware:childCount",
      "@type": "rdf:Property",
      "rdfs:comment": "Count of child organization elements (immediate children) of this organization element. This value is set automatically by API."
    },
    "sortPosition": {
      "@id": "basware:sortPosition",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies the sorting position for organization elements under the same parent element. Used for placement of the company within the organization tree in UI."
    },
    "parentType": {
      "@id": "basware:parentType",
      "@type": "rdf:Property"
    },
    "parentCodes": {
      "@id": "basware:parentCodes",
      "@type": "rdf:Property"
    },
    "parents": {
      "@id": "basware:parents",
      "@type": "rdf:Property"
    },
    "paymentDate": {
      "@id": "basware:paymentDate",
      "@type": "rdf:Property",
      "rdfs:comment": "Date when the invoice was paid can be updated here."
    },
    "paidTotal": {
      "@id": "basware:paidTotal",
      "@type": "rdf:Property",
      "rdfs:comment": "Total amount paid for the invoice so far. For partial payments, this value will increase each time more of the invoice is paid."
    },
    "cashDiscount": {
      "@id": "basware:cashDiscount",
      "@type": "rdf:Property",
      "rdfs:comment": "discount amount can be updated here."
    },
    "checkNumber": {
      "@id": "basware:checkNumber",
      "@type": "rdf:Property",
      "rdfs:comment": "Unique identifier from the check used in payment transaction."
    },
    "paymentNumber": {
      "@id": "basware:paymentNumber",
      "@type": "rdf:Property",
      "rdfs:comment": "Payment number can be updated here."
    },
    "paymentDocument": {
      "@id": "basware:paymentDocument",
      "@type": "rdf:Property",
      "rdfs:comment": "Payment document number can be updated here."
    },
    "paymentReversalDocument": {
      "@id": "basware:paymentReversalDocument",
      "@type": "rdf:Property",
      "rdfs:comment": "Payment reversal document can be updated here."
    },
    "discountDays": {
      "@id": "basware:discountDays",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines number of days used in dynamic cash discount. The number of days must be unique for each discount percentage."
    },
    "paymentTermNames": {
      "@id": "basware:paymentTermNames",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines name(s) for the payment term. Please always include 'en-US' language tag for Basware global support, as well as any local-language tag being used. If both translations are not available, pleas"
    },
    "sortOrder": {
      "@id": "basware:sortOrder",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies position of a payment term in selection list."
    },
    "moveDueDatesTo": {
      "@id": "basware:moveDueDatesTo",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies whether to move due date and cash date to next/previous working day (in case due date occurs during weekend). \r 0 = Do not move due date.\r 1 = Move to next working day.\r 2 = Move to previous"
    },
    "dueDateCalc": {
      "@id": "basware:dueDateCalc",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies due date calculation method. \r 1 = Due date is calculated automatically according to rules specified in this payment term. \r 0 = Due date is entered manually (no automatic calculation)."
    },
    "dueDateDays": {
      "@id": "basware:dueDateDays",
      "@type": "rdf:Property",
      "rdfs:comment": "Used in due date calculation. Specifies number of days to be added to the base date."
    },
    "dueDateDays2": {
      "@id": "basware:dueDateDays2",
      "@type": "rdf:Property",
      "rdfs:comment": "Used in due date calculation. Specifies the amount of days to be added after month-end -moves."
    },
    "dueDateEom": {
      "@id": "basware:dueDateEom",
      "@type": "rdf:Property",
      "rdfs:comment": "Accepts integer values from 0 to 12 only.\r Used in due date calculation. Specifies number of month-ends to be added to due date. Month-ends are added after adding dueDateDays to base calculation date."
    },
    "cashDueDateCalc": {
      "@id": "basware:cashDueDateCalc",
      "@type": "rdf:Property",
      "rdfs:comment": "Specifies cash date calculation method.\r 0 = Cash date is entered manually (no calculation)\r 1 = Calculate cash date (accorging to rules specified on this payment term)\r 2 = Calculate dynamic cash dat"
    },
    "cashDueDateDays": {
      "@id": "basware:cashDueDateDays",
      "@type": "rdf:Property",
      "rdfs:comment": "Used in cash date calculation. Specifies number of days to be added to the base date."
    },
    "cashDueDateDays2": {
      "@id": "basware:cashDueDateDays2",
      "@type": "rdf:Property",
      "rdfs:comment": "Used in cash date calculation. Specifies the amount of days to be added after month-end -moves."
    },
    "cashDueDateEom": {
      "@id": "basware:cashDueDateEom",
      "@type": "rdf:Property",
      "rdfs:comment": "Accepts integer values from 0 to 12 only.\r Used in cash date calculation. Specifies number of month-ends to be added to cash date. Month-ends are added after adding dueDateDays to base calculation dat"
    },
    "paymentTermDiscountRules": {
      "@id": "basware:paymentTermDiscountRules",
      "@type": "rdf:Property",
      "rdfs:comment": "PaymentTermDiscountRules can be used to specify multiple cash discount dates. Data is imported to \"Calculate cynamic cash date and cash discount\" -section in P2P. \r To enable cash discount calculation"
    },
    "paymentTerms": {
      "@id": "basware:paymentTerms",
      "@type": "rdf:Property"
    },
    "prebookDate": {
      "@id": "basware:prebookDate",
      "@type": "rdf:Property",
      "rdfs:comment": "Prebook date. Note: Field is not saved to P2P (P2P saves the moment when prebook response message arrives)."
    },
    "requestIds": {
      "@id": "basware:requestIds",
      "@type": "rdf:Property",
      "rdfs:comment": "List of requestIds to acknowledge. Several requests can be acknowledged in one operation."
    },
    "projectNames": {
      "@id": "basware:projectNames",
      "@type": "rdf:Property",
      "rdfs:comment": "Defines name(s) for the project. Please always include 'en-US' language tag for Basware global support, as well as any local-language tag being used. If both translations are not available, please use"
    },
    "projects": {
      "@id": "basware:projects",
      "@type": "rdf:Property"
    },
    "externalcodes": {
      "@id": "basware:externalcodes",
